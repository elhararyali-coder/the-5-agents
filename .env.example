# ====================================================================
# the-5-agents — קובץ דוגמה למשתני סביבה
# ====================================================================
# העתק קובץ זה ל-.env ומלא את הערכים האמיתיים.
# קובץ .env עצמו לא נכנס ל-git (ראה .gitignore) — אל תשתף אותו.
# --------------------------------------------------------------------

# --- ליבת המערכת: Claude (ראובן, יעל וכל הסוכנים) ---
# מפתח ה-API של Anthropic. השג אותו ב-https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- יובל — מעצב התמונות ---
# מפתח לשירות יצירת התמונות (למשל OpenAI / שירות אחר).
IMAGE_API_KEY=

# --- חן — החוקרת ---
# מפתח לשירות חיפוש/מחקר (למשל Tavily / Brave Search).
SEARCH_API_KEY=
